# LiveKit room connection
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# LiveKit Agents provider selection
RMCC_STT_MODEL=deepgram/nova-3
RMCC_STT_LANGUAGE=en-GB
RMCC_LLM_MODEL=openai/gpt-4.1-mini
RMCC_ENABLE_TTS=true
RMCC_TTS_MODEL=cartesia/sonic-3
RMCC_TTS_VOICE=3c0f09d6-e0d7-499c-a594-70c5b7b93048

# Provider keys, depending on your chosen LiveKit/plugin setup
OPENAI_API_KEY=
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=

# Future optional ElevenLabs TTS provider. Keep server-side only.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Protected RMCC MCP bridge. Do not point the voice agent at Supabase directly.
RMCC_MCP_URL=https://rmg-command-centre-new.pages.dev/mcp
RMCC_MCP_TOKEN=
RMCC_API_TIMEOUT=20

# Backwards-compatible aliases for older local setups.
RMCC_API_BASE_URL=
RMCC_API_TOKEN=
